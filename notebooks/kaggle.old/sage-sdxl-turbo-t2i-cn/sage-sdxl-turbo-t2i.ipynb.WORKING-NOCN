   "source": [
    "# --------------------------\n",
    "# FastAPI app init\n",
    "# --------------------------\n",
    "\n",
    "from fastapi import FastAPI\n",
    "import nest_asyncio\n",
    "import uvicorn\n",
    "\n",
    "app = FastAPI()\n",
    "nest_asyncio.apply()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {
    "trusted": true
   },
   "outputs": [],
   "source": [
    "# ---------------------------\n",
    "# API Endpoint\n",
    "# ---------------------------\n",
    "\n",
    "from fastapi import Form, UploadFile, File\n",
    "from fastapi.responses import StreamingResponse, JSONResponse\n",
    "from io import BytesIO\n",
    "from PIL import Image\n",
    "\n",
    "@app.post(\"/generate\")\n",
    "async def generate(\n",
    "    prompt: str = Form(...),\n",
    "    negative_prompt: str = Form(\"\"),\n",
    "    height: int = Form(512),\n",
    "    width: int = Form(512),\n",
    "    num_inference_steps: int = Form(1),       # Turbo Default: 1\n",
    "    guidance_scale: float = Form(0.0),        # Turbo Default: 0.0\n",
    "    seed: int = Form(None),\n",
    "    strength: float = Form(0.5),\n",
    "    init_image: UploadFile = File(None),\n",
    "):\n",
    "    # --- Check Mode Compatibility ---\n",
    "    if USE_IMG2IMG and init_image is None:\n",
    "        return JSONResponse(status_code=400, content={\"error\": \"Notebook configured for Img2Img, but no init_image provided.\"})\n",
    "    \n",
    "    if not USE_IMG2IMG and init_image is not None:\n",
    "        return JSONResponse(status_code=400, content={\"error\": \"Notebook configured for Txt2Img, but init_image was provided. Change USE_IMG2IMG to True to use image input.\"})\n",
    "\n",
    "    # --- Prepare Init Image ---\n",
    "    pil_init_image = None\n",
    "    if init_image is not None:\n",
    "        try:\n",
    "            pil_init_image = Image.open(BytesIO(await init_image.read())).convert(\"RGB\")\n",
    "        except Exception as e:\n",
    "            return JSONResponse(\n",
    "                status_code=400,\n",
    "                content={\"error\": f\"Failed to read init_image: {str(e)}\"},\n",
    "            )\n",
    "\n",
    "    # --- Generate ---\n",
    "    try:\n",
    "        generated_image = generate_sdxl_turbo(\n",
    "            pipe=pipe,\n",
    "            prompt=prompt,\n",
    "            negative_prompt=negative_prompt,\n",
    "            init_image=pil_init_image,\n",
    "            strength=strength,\n",
    "            num_inference_steps=num_inference_steps,\n",
    "            guidance_scale=guidance_scale,\n",
    "            seed=seed,\n",
    "            height=height,\n",
    "            width=width\n",
    "        )\n",
    "    except Exception as e:\n",
    "        import traceback\n",
    "        traceback.print_exc()\n",
    "        return JSONResponse(status_code=500, content={\"error\": str(e)})\n",
    "\n",
    "    # --- Return PNG stream ---\n",
    "    buffer = BytesIO()\n",
    "    generated_image.save(buffer, format=\"PNG\")\n",
    "    buffer.seek(0)\n",
    "    return StreamingResponse(buffer, media_type=\"image/png\")"
   ]
  },
