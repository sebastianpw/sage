    "# Download zrok v1.1.3 (latest)\n",
    "!wget https://github.com/openziti/zrok/releases/download/v1.1.3/zrok_1.1.3_linux_amd64.tar.gz\n",
    "!tar -xzf zrok_1.1.3_linux_amd64.tar.gz\n",
    "!chmod +x zrok"
   ]
  },
