    "import time\n",
    "\n",
    "print(\"Server and zrok tunnel are running. Keeping the notebook alive...\")\n",
    "\n",
    "try:\n",
    "    while True:\n",
    "        time.sleep(60)\n",
    "except KeyboardInterrupt:\n",
    "    print(\"Shutting down.\")"
   ]
  }
